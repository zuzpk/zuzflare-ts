{
  "name": "frontend-flare",
  "version": "1.1.2",
  "private": true,
  "scripts": {
    "css-fix": "sudo npm i -g style-loader css-loader sass-loader",
    "dev": "concurrently -n \"ZUZJS-UI,ZUZ.JS,ZAPP\" -c \"blue,yellow,green\" \"zuzjs watch\" \"node zuz.js mode=dev dir=.next.dev\" \"next dev -p 3000 --webpack\"",
    "build": "node zuz.js mode=prod dir=.next.build && next build --webpack",
    "start": "next start -p 3000",
    "lint": "next lint",
    "prepare": "husky"
  },
  "dependencies": {
    "@zuzjs/core": "^0.3.17",
    "@zuzjs/flare": "^0.2.16",
    "@zuzjs/flare-admin": "^0.1.3",
    "@zuzjs/hooks": "^0.1.20",
    "@zuzjs/logger": "^0.1.9",
    "@zuzjs/store": "^0.1.8",
    "@zuzjs/ui": "^1.0.75",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "babel-plugin-react-compiler": "1.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^10.1.0",
    "eslint-config-next": "16.2.1",
    "husky": "^9.1.7",
    "sass": "^1.98.0",
    "style-loader": "^4.0.0",
    "typescript": "^6.0.2"
  }
}